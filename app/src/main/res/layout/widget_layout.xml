<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_bg"
    android:padding="12dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TimePlans"
            android:textStyle="bold"
            android:textColor="#38BDF8"
            android:textSize="12sp"
            android:layout_alignParentStart="true" />

        <TextView
            android:id="@+id/widget_attendance_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Status: Present"
            android:textColor="#34D399"
            android:textSize="10sp"
            android:layout_alignParentEnd="true" />
    </RelativeLayout>

    <TextView
        android:id="@+id/widget_current_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CURRENT CLASS"
        android:textColor="#94A3B8"
        android:textSize="9sp"
        android:textStyle="bold"
        android:layout_marginTop="8dp" />

    <TextView
        android:id="@+id/widget_lesson_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Free Time"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:layout_marginTop="2dp"
        android:singleLine="true"
        android:ellipsize="end" />

    <TextView
        android:id="@+id/widget_lesson_details"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No current lessons"
        android:textColor="#CBD5E1"
        android:textSize="11sp"
        android:layout_marginTop="1dp" />

    <TextView
        android:id="@+id/widget_next_lesson"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Next: --"
        android:textColor="#94A3B8"
        android:textSize="10sp"
        android:layout_marginTop="8dp"
        android:singleLine="true"
        android:ellipsize="end" />
</LinearLayout>
